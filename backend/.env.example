# =============================================
# DATABASE
# =============================================
DATABASE_URL="postgresql://username:password@localhost:5432/chatbot_db?schema=public"

# =============================================
# GROQ API (Primary Provider — Cloud)
# Lấy key tại: https://console.groq.com
# =============================================
GROQ_API_KEY="your_groq_api_key_here"
GROQ_DEFAULT_MODEL="llama-3.3-70b-versatile"

# =============================================
# LM STUDIO (Fallback Provider — Local)
# Mở LM Studio → load model → bật server tại localhost:1234
# =============================================
LMSTUDIO_BASE_URL="http://localhost:1234/v1"
LMSTUDIO_DEFAULT_MODEL="qwen-2.5-coder-7b-instruct"
LMSTUDIO_EMBEDDING_MODEL="text-embedding-nomic-embed-text-v1.5"
EMBEDDING_DIMENSION=768

# =============================================
# APP CONFIG
# =============================================
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
